# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key

# Admin Settings (comma-separated allowlist for /lab and /api/lab/*)
# Required: if unset/empty, ALL admin access is denied (fail closed).
ADMIN_EMAILS=owner@example.com

# Rate limiting (distributed store).
# REQUIRED in production: without these, rate limiting degrades to per-instance
# in-memory buckets that a serverless deployment cannot enforce globally.
# Create a free database at https://console.upstash.com (Redis) and paste its
# REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Payments Configuration (Base Mainnet)
X402_PAYOUT_ADDRESS=your_evm_receiving_wallet_address
X402_NETWORK=base
# Optional: dedicated RPC endpoint (defaults to the public https://mainnet.base.org)
# BASE_RPC_URL=

# Standard x402 settlement (EIP-3009 TransferWithAuthorization).
# Bankr agents, x402-fetch, and most agent wallets sign a gasless authorization
# and expect the SELLER to settle it. We settle through an x402 facilitator,
# which broadcasts the transfer and pays gas — free for us. Default is PayAI's
# public facilitator (no API key, supports `exact` on Base mainnet). Override
# with e.g. Coinbase CDP's facilitator if you have CDP credentials.
# X402_FACILITATOR_URL=https://facilitator.payai.network
# Set to false to refuse eip3009 payloads and accept only self-settled txHash.
# X402_FACILITATOR_ENABLED=true

# Solana Payments Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PAYOUT_ADDRESS=your_solana_receiving_wallet_address

# Payment verification hardening (safe defaults shown)
# Require the paying wallet to sign a binding challenge, so a public txHash
# cannot be redeemed by anyone who merely observed it (front-running). Set to
# false only if your agents cannot sign — payments stay single-use, but are no
# longer bound to the payer. The 402 quote advertises the exact challenge.
# NOTE: this flag is IGNORED in production (VERCEL_ENV/NODE_ENV=production),
# where binding is always enforced.
REQUIRE_PAYMENT_BINDING=true
# Minimum Base confirmations before a payment is accepted (reorg safety).
MIN_EVM_CONFIRMATIONS=1
# Reject settlements older than this many seconds (0 disables the check).
# Default matches the 402 quote's advertised 24h validity window.
PAYMENT_MAX_AGE_SECONDS=86400

# Scenario Battery Evals scoring mode.
# Default (unset/false): FREE deterministic heuristic scorer — zero inference
# cost, fully reproducible. Set to 'true' (and provide a provider key below) to
# upgrade to the higher-nuance LLM judge, which costs inference per scoring run.
# The buyer pays before scoring runs, so the LLM path stays revenue-positive.
# EVAL_USE_LLM_JUDGE=false

# LLM Providers (set the ones your generators' model_config uses)
OPENROUTER_API_KEY=your_openrouter_key
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Test Buyer Private Key (for scripts/buyer-test.ts locally)
# ONLY set in local .env, NEVER deploy this private key to Vercel/production!
TEST_BUYER_PRIVATE_KEY=your_test_buyer_private_key

# On-chain registry deployment / dataset registration (scripts/deploy-registry.ts,
# scripts/register-datasets.ts). Wallet that signs settlement/registry txs.
# ONLY set in local .env, NEVER commit or deploy this private key!
SETTLEMENT_PRIVATE_KEY=your_settlement_private_key
